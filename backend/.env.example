PORT=3002
NODE_ENV=development

MONGODB_URI=mongodb://localhost:27017/hytrade
JWT_SECRET=change-me-to-a-long-random-secret

# Market data (required) — get a free key at https://finnhub.io
MARKET_DATA_PROVIDER=finnhub
MARKET_DATA_API_KEY=your_finnhub_api_key

# Paper trading
STARTING_BALANCE_INR=100000
LIMIT_ORDER_BAND_PCT=5
QUOTE_CACHE_TTL_MS=60000

# Auth
JWT_EXPIRES_IN=24h
BCRYPT_ROUNDS=12
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_TIME=900000

# Optional AWS S3 for profile avatars
# AWS_REGION=ap-south-1
# AWS_S3_BUCKET=
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_S3_PUBLIC_BASE_URL=
